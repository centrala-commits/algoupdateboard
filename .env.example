# ============================================================================
#  Copy this file to ".env" and fill in your own values.  ".env" is gitignored.
# ============================================================================
#  VITE_*  -> PUBLIC (compiled into the browser bundle). No secrets here.
#  others  -> private / server-side only. Real secrets go here (never VITE_).
# ============================================================================

# ---------- Front-end (PUBLIC) ----------------------------------------------
VITE_APP_NAME="AG Dispatch"
VITE_AUTH_USERS=admin:changeme,dispatcher:changeme

# ---------- Supabase (database) — Settings -> API in your project -----------
# anon key is public (RLS guards data). Blank = run on local seed, no DB.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ---------- Server (private) ------------------------------------------------
NODE_ENV=development
PORT=4000
HOST=0.0.0.0

# ---------- Database (private) ----------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=your_database
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DATABASE_URL=postgresql://your_db_user:your_db_password@localhost:5432/your_database

# ---------- Auth / sessions (private) ---------------------------------------
SESSION_SECRET=replace-with-a-long-random-string
JWT_SECRET=replace-with-a-long-random-string

# ---------- Admin / contact names (private) ---------------------------------
ADMIN_NAME="Your Name"
ADMIN_EMAIL=you@example.com
